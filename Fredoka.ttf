"""
Bibliotheque d'illustrations vectorielles - Assistant Sequences Cycle 2
=======================================================================
Genere des illustrations crayonnees (style "fait main") en SVG -> PNG.
Toutes les formes ont un leger tremblement pour eviter l'aspect "genere par IA".

Dependances : cairosvg  (pip install cairosvg --break-system-packages)

Usage :
    from illustrations import *
    save_png("pomme", aliment_pomme(), 120, 120)
    save_png("horloge_3h", horloge(3, 0), 150, 150)
    save_png("mascotte", mascotte_renard(), 120, 130)
"""
import cairosvg, math, random

random.seed(7)
PALETTE = {
    'rouge':'#E8615A','orange':'#F2A65A','jaune':'#F4C95D','vert':'#7FB069',
    'vertfonce':'#5C8A4A','bleu':'#5B9BD5','turquoise':'#5BC0DE','bleunuit':'#3D5A80',
    'violet':'#9B72AA','rose':'#E89BB0','marron':'#A67C52','creme':'#FBF7F0','encre':'#3A3A3A'
}

def save_png(name, svg, w, h, scale=3):
    """Convertit une chaine SVG en PNG transparent haute resolution."""
    cairosvg.svg2png(bytestring=svg.encode(), write_to=f"{name}.png",
                     output_width=int(w*scale), output_height=int(h*scale),
                     background_color=None)

# ---------- Helpers "fait main" ----------
def _wobble(points, amp=1.8):
    return [(x+random.uniform(-amp,amp), y+random.uniform(-amp,amp)) for (x,y) in points]

def _path(points, close=True):
    d = f"M{points[0][0]:.1f},{points[0][1]:.1f} " + " ".join(
        f"L{p[0]:.1f},{p[1]:.1f}" for p in points[1:])
    return d + (" Z" if close else "")

def _crayon_circle(cx, cy, r, n=40, amp=2.2):
    pts=[]
    for i in range(n+1):
        a=2*math.pi*i/n
        rr=r+random.uniform(-amp,amp)
        pts.append((cx+rr*math.cos(a), cy+rr*math.sin(a)))
    return pts

def _wrap(inner, w, h):
    return (f'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 {w} {h}" '
            f'width="{w}" height="{h}">{inner}</svg>')

C = PALETTE  # raccourci

# ---------- ALIMENTS ----------
def aliment_pomme():
    body=_path(_crayon_circle(60,68,34,amp=2.5))
    s=f'<path d="{body}" fill="{C["rouge"]}" stroke="{C["encre"]}" stroke-width="2.5" stroke-linejoin="round"/>'
    s+=f'<path d="M60,36 C61,28 64,22 71,19" fill="none" stroke="{C["marron"]}" stroke-width="3" stroke-linecap="round"/>'
    s+=f'<path d="{_path(_wobble([(66,24),(80,16),(84,26),(70,30)],1.2))}" fill="{C["vert"]}" stroke="{C["encre"]}" stroke-width="2"/>'
    s+=f'<path d="M50,58 C54,54 58,54 60,58" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" opacity="0.6"/>'
    return _wrap(s,120,120)

def aliment_banane():
    pts=_wobble([(30,40),(42,32),(70,40),(92,70),(86,86),(72,80),(50,66),(34,50)],1.6)
    s=f'<path d="{_path(pts)}" fill="{C["jaune"]}" stroke="{C["encre"]}" stroke-width="2.5" stroke-linejoin="round"/>'
    s+=f'<path d="M30,40 L26,34" stroke="{C["marron"]}" stroke-width="4" stroke-linecap="round"/>'
    return _wrap(s,120,120)

def aliment_carotte():
    s=f'<path d="{_path(_wobble([(50,52),(70,52),(61,120)],1.6))}" fill="{C["orange"]}" stroke="{C["encre"]}" stroke-width="2.5" stroke-linejoin="round"/>'
    for y in (66,82,98):
        s+=f'<path d="M{53+random.uniform(-1,1):.1f},{y} L{67+random.uniform(-1,1):.1f},{y-2}" stroke="{C["encre"]}" stroke-width="1.6" stroke-linecap="round"/>'
    for sk in ('M50,52 C40,30 46,20 50,14','M60,52 C60,28 60,18 60,12','M70,52 C80,30 74,20 70,14'):
        s+=f'<path d="{sk}" fill="none" stroke="{C["vert"]}" stroke-width="4" stroke-linecap="round"/>'
    return _wrap(s,120,140)

def aliment_fromage():
    s=f'<path d="{_path(_wobble([(28,82),(28,56),(128,56),(128,82)],1.4))}" fill="{C["jaune"]}" stroke="{C["encre"]}" stroke-width="2.5" stroke-linejoin="round"/>'
    s+=f'<path d="{_path(_wobble([(28,56),(80,30),(128,56)],1.4))}" fill="#F8D77E" stroke="{C["encre"]}" stroke-width="2.5" stroke-linejoin="round"/>'
    for (cx,cy,r) in ((60,68,6),(95,64,5),(110,74,4)):
        s+=f'<path d="{_path(_crayon_circle(cx,cy,r,16,1.0))}" fill="{C["orange"]}" stroke="{C["encre"]}" stroke-width="1.6"/>'
    return _wrap(s,150,120)

def aliment_pain():
    s=f'<path d="{_path(_wobble([(24,80),(24,58),(34,44),(116,44),(126,58),(126,80)],1.6))}" fill="{C["marron"]}" stroke="{C["encre"]}" stroke-width="2.5" stroke-linejoin="round"/>'
    for x in (50,75,100):
        s+=f'<path d="M{x},48 L{x-6},42" stroke="{C["encre"]}" stroke-width="2" stroke-linecap="round"/>'
    return _wrap(s,150,110)

def aliment_lait():
    s=f'<path d="{_path(_wobble([(45,40),(75,40),(80,110),(40,110)],1.4))}" fill="{C["creme"]}" stroke="{C["encre"]}" stroke-width="2.5" stroke-linejoin="round"/>'
    s+=f'<path d="M45,40 L52,24 L68,24 L75,40" fill="{C["bleu"]}" stroke="{C["encre"]}" stroke-width="2.5" stroke-linejoin="round"/>'
    s+=f'<rect x="46" y="60" width="28" height="22" rx="3" fill="#fff" stroke="{C["encre"]}" stroke-width="1.6"/>'
    return _wrap(s,120,130)

def aliment_bonbon():
    s=f'<path d="{_path(_crayon_circle(60,60,22,24,1.6))}" fill="{C["rose"]}" stroke="{C["encre"]}" stroke-width="2.5"/>'
    s+=f'<path d="M38,60 L18,48 L24,60 L18,72 Z" fill="{C["violet"]}" stroke="{C["encre"]}" stroke-width="2"/>'
    s+=f'<path d="M82,60 L102,48 L96,60 L102,72 Z" fill="{C["violet"]}" stroke="{C["encre"]}" stroke-width="2"/>'
    return _wrap(s,120,120)

# ---------- SANTE ----------
def dent_brosse():
    body=_path(_wobble([(46,28),(74,28),(86,40),(88,72),(80,104),(70,96),(60,98),(50,96),(40,104),(32,72),(34,40)],1.6))
    s=f'<path d="{body}" fill="#FFFFFF" stroke="{C["encre"]}" stroke-width="2.5" stroke-linejoin="round"/>'
    s+=f'<rect x="98" y="44" width="14" height="56" rx="6" fill="{C["bleu"]}" stroke="{C["encre"]}" stroke-width="2.2"/>'
    for x in (101,105,109):
        s+=f'<path d="M{x},44 L{x},34" stroke="{C["vertfonce"]}" stroke-width="2.4" stroke-linecap="round"/>'
    return _wrap(s,130,120)

# ---------- TEMPS / HORLOGES ----------
def horloge(h, m=0, numbers=True, hands=True, size=150):
    """Horloge analogique. hands=False -> cadran vide (a completer)."""
    cx=cy=size/2; R=size/2-8
    s=f'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 {size} {size}" width="{size}" height="{size}">'
    s+=f'<circle cx="{cx}" cy="{cy}" r="{R}" fill="#FFFFFF" stroke="{C["encre"]}" stroke-width="3.5"/>'
    s+=f'<circle cx="{cx}" cy="{cy}" r="{R-5}" fill="none" stroke="{C["bleu"]}" stroke-width="1.4" opacity="0.5"/>'
    for i in range(12):
        a=math.radians(i*30-90)
        x1=cx+(R-3)*math.cos(a); y1=cy+(R-3)*math.sin(a)
        x2=cx+(R-9)*math.cos(a); y2=cy+(R-9)*math.sin(a)
        s+=f'<line x1="{x1:.1f}" y1="{y1:.1f}" x2="{x2:.1f}" y2="{y2:.1f}" stroke="{C["encre"]}" stroke-width="2"/>'
    if numbers:
        for i in range(1,13):
            a=math.radians(i*30-90)
            x=cx+(R-20)*math.cos(a); y=cy+(R-20)*math.sin(a)
            s+=f'<text x="{x:.1f}" y="{y+4:.1f}" font-family="Baloo 2" font-size="14" fill="{C["rouge"]}" text-anchor="middle">{i}</text>'
    if hands:
        ah=math.radians((h%12)*30 + m*0.5 -90)
        s+=f'<line x1="{cx}" y1="{cy}" x2="{cx+(R-42)*math.cos(ah):.1f}" y2="{cy+(R-42)*math.sin(ah):.1f}" stroke="{C["bleunuit"]}" stroke-width="4.5" stroke-linecap="round"/>'
        am=math.radians(m*6-90)
        s+=f'<line x1="{cx}" y1="{cy}" x2="{cx+(R-22)*math.cos(am):.1f}" y2="{cy+(R-22)*math.sin(am):.1f}" stroke="{C["rouge"]}" stroke-width="3" stroke-linecap="round"/>'
    s+=f'<circle cx="{cx}" cy="{cy}" r="4" fill="{C["encre"]}"/></svg>'
    return s

# ---------- DECORS ----------
def assiette_vide(w=220, h=138):
    return (f'<svg xmlns="http://www.w3.org/2000/svg" width="{w}" height="{h}" viewBox="0 0 {w} {h}">'
            f'<ellipse cx="{w/2}" cy="{h/2}" rx="{w/2-16}" ry="{h/2-12}" fill="{C["creme"]}" stroke="{C["encre"]}" stroke-width="3"/>'
            f'<ellipse cx="{w/2}" cy="{h/2}" rx="{w/2-40}" ry="{h/2-28}" fill="none" stroke="#c4c4c4" stroke-width="2" stroke-dasharray="5 4"/></svg>')

def etoile():
    return ('<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 50 50" width="50" height="50">'
            f'<path d="M25 6 L30 19 L44 20 L33 29 L37 43 L25 35 L13 43 L17 29 L6 20 L20 19 Z" '
            f'fill="{C["jaune"]}" stroke="{C["encre"]}" stroke-width="2.2" stroke-linejoin="round"/></svg>')

# ---------- MASCOTTE (constante d'une fiche a l'autre) ----------
def mascotte_renard():
    s='<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 130" width="120" height="130">'
    s+=f'<path d="M40 128 C38 100 35 92 48 86 L72 86 C85 92 82 100 80 128 Z" fill="{C["orange"]}" stroke="{C["encre"]}" stroke-width="2.5" stroke-linejoin="round"/>'
    s+=f'<path d="M30 50 C30 28 45 18 60 18 C75 18 90 28 90 50 C90 70 76 82 60 82 C44 82 30 70 30 50 Z" fill="{C["orange"]}" stroke="{C["encre"]}" stroke-width="2.5"/>'
    s+=f'<path d="M34 34 L24 10 L46 24 Z" fill="{C["orange"]}" stroke="{C["encre"]}" stroke-width="2.5" stroke-linejoin="round"/>'
    s+=f'<path d="M86 34 L96 10 L74 24 Z" fill="{C["orange"]}" stroke="{C["encre"]}" stroke-width="2.5" stroke-linejoin="round"/>'
    s+=f'<path d="M33 30 L28 16 L40 24 Z" fill="{C["encre"]}"/><path d="M87 30 L92 16 L80 24 Z" fill="{C["encre"]}"/>'
    s+=f'<path d="M44 56 C44 44 76 44 76 56 C76 72 60 80 60 80 C60 80 44 72 44 56 Z" fill="{C["creme"]}" stroke="{C["encre"]}" stroke-width="2"/>'
    s+=f'<circle cx="50" cy="50" r="3.4" fill="{C["encre"]}"/><circle cx="70" cy="50" r="3.4" fill="{C["encre"]}"/>'
    s+=f'<path d="M56 62 L64 62 L60 68 Z" fill="{C["encre"]}"/>'
    s+=f'<path d="M60 68 C56 74 52 73 50 70" fill="none" stroke="{C["encre"]}" stroke-width="1.8" stroke-linecap="round"/>'
    s+=f'<path d="M60 68 C64 74 68 73 70 70" fill="none" stroke="{C["encre"]}" stroke-width="1.8" stroke-linecap="round"/>'
    s+=f'<path d="M80 92 C95 90 100 84 102 78" fill="none" stroke="{C["encre"]}" stroke-width="2.5" stroke-linecap="round"/>'
    s+=f'<circle cx="103" cy="76" r="5" fill="{C["orange"]}" stroke="{C["encre"]}" stroke-width="2"/></svg>'
    return s

if __name__ == "__main__":
    # Demo : genere quelques illustrations
    save_png("demo_pomme", aliment_pomme(), 120, 120)
    save_png("demo_horloge", horloge(3, 0), 150, 150)
    save_png("demo_mascotte", mascotte_renard(), 120, 130)
    print("Illustrations de demonstration generees.")
